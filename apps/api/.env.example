# OpenRouter — get a key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Postgres — Neon or any PostgreSQL provider
# In dev, leave unset to use the in-memory store (no persistence across restarts)
POSTGRES_URL=postgres://user:password@host/dbname

# Brave Search — get a key at https://brave.com/search/api/
BRAVE_API_KEY=your_brave_search_api_key_here

# Model overrides (optional — defaults shown)
EXTRACTION_MODEL=google/gemini-2.5-flash-lite
SCORING_MODEL=anthropic/claude-sonnet-4-5

# Your deployment URL (used for OpenRouter HTTP-Referer header)
SITE_URL=https://your-deployment-url.vercel.app

# Shared abuse-mitigation token. When set, requests must send it in the
# X-ES-Token header. Build the extension with the same value (API_TOKEN env).
# Leave unset to disable (local dev).
EXTENSION_API_TOKEN=generate_a_long_random_string_here
