# Google AI API Key - Get one from https://ai.google.dev/
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# OpenAI API Key - Get one from https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Backend Port - Port the server will listen on (default: 3000)
BACKEND_PORT=3000

# eBay API Keys - Get them from https://developer.ebay.com/
EBAY_APP_ID=***REMOVED***
EBAY_CERT_ID=***REMOVED***