# Google AI API Key - Get one from https://ai.google.dev/
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# OpenAI API Key - Get one from https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Backend Port - Port the server will listen on (default: 3000)
BACKEND_PORT=3000

# eBay API Keys - Get them from https://developer.ebay.com/
EBAY_APP_ID=***REMOVED***
EBAY_CERT_ID=***REMOVED***

# Reddit API OAuth Credentials - Get them from https://www.reddit.com/prefs/apps
# Create a "script" app to get these credentials
REDDIT_CLIENT_ID=***REMOVED***
REDDIT_CLIENT_SECRET=***REMOVED***
REDDIT_USERNAME=your_reddit_username_here
REDDIT_PASSWORD=your_reddit_password_here
REDDIT_USER_AGENT=EthicalShopper/1.0.0 by ***REMOVED***