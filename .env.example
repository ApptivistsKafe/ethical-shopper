# Root-level environment for local tooling (MCP servers, etc.).
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
#
#   cp .env.example .env
#
# Brave Search API key — used by the `brave-search` MCP server in .vscode/mcp.json.
# Get one at https://brave.com/search/api/
BRAVE_API_KEY=your_brave_search_api_key_here
